{
    "name": "cbs-3d-sehir-modeli",
    "version": "0.9.3.1",
    "private": true,
    "type": "module",
    "scripts": {
        "tw:build": "tailwindcss -c ./tailwind.config.cjs -i ./app/tailwind.input.css -o ./app/tailwind.generated.css --minify",
        "dev": "npm run tw:build && vite",
        "build": "npm run tw:build && vite build",
        "build:deploy": "npm run build && node scripts/build-deploy-package.mjs",
        "build:deploy:light": "npm run build && node scripts/build-deploy-package.mjs --light",
        "build:deploy:dry": "npm run build && node scripts/build-deploy-package.mjs --dry-run",
        "build:deploy:full": "npm run build && node scripts/build-deploy-package.mjs --with-big-data",
        "build:deploy:dry:full": "npm run build && node scripts/build-deploy-package.mjs --dry-run --with-big-data",
        "preview": "vite preview"
    },
    "devDependencies": {
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/forms": "^0.5.11",
        "autoprefixer": "^10.4.27",
        "postcss": "^8.5.8",
        "tailwindcss": "^3.4.17",
        "vite": "^5.0.0",
        "vite-plugin-cesium": "^1.2.22"
    },
    "dependencies": {
        "cesium": "^1.105.0",
        "proj4": "^2.9.0"
    }
}
